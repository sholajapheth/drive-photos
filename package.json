{
  "name": "drive-photos",
  "private": true,
  "description": "Google Drive photo folder integration for React and Next.js apps",
  "author": {
    "name": "Shola Japheth",
    "url": "https://github.com/sholajapheth"
  },
  "homepage": "https://drive-photos.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/sholajapheth/drive-photos"
  },
  "bugs": {
    "url": "https://github.com/sholajapheth/drive-photos/issues"
  },
  "keywords": [
    "google-drive",
    "photo-gallery",
    "react",
    "nextjs",
    "images",
    "drive-photos",
    "google-drive-api",
    "image-gallery",
    "react-gdrive"
  ],
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w drive-photos-docs",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "audit": "npm audit --audit-level=high",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "turbo run build --filter='./packages/*' && changeset publish",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "rimraf": "^5.0.5",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.8.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=18"
  }
}
