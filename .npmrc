# Scoped packages publish as public by default when publishConfig.access is set per package.
@sholajapheth:registry=https://registry.npmjs.org/

# Do not commit auth tokens. Set NPM_TOKEN in CI (e.g. setup-node) or locally via `npm login`.

# Install scripts run by default so native tooling (e.g. esbuild) works. For dependency-only CI installs
# with no native modules, you may set ignore-scripts=true in that environment.
ignore-scripts=false
