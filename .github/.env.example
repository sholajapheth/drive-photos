# Copy values into apps/docs/.env.local for local docs — do not commit secrets.

# @drive-photos/next proxy routes (server-only)
GOOGLE_DRIVE_API_KEY=your_api_key_here

# Default folder for list routes (optional if you pass folder per request)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_or_url_here

# Docs demo (client-safe folder id for the live gallery)
NEXT_PUBLIC_DEMO_FOLDER_ID=your_public_demo_folder_id
