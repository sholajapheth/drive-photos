{
  "name": "@drive-photos/core",
  "version": "0.1.0",
  "description": "Framework-agnostic Google Drive photo listing, validation, and image fallback utilities",
  "license": "MIT",
  "author": {
    "name": "Shola Japheth",
    "url": "https://github.com/sholajapheth"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sholajapheth/drive-photos",
    "directory": "packages/core"
  },
  "homepage": "https://drive-photos.dev",
  "bugs": {
    "url": "https://github.com/sholajapheth/drive-photos/issues"
  },
  "keywords": [
    "google-drive",
    "photo-gallery",
    "images",
    "drive",
    "gallery",
    "google-drive-api",
    "photo-folder",
    "drive-photos"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src __tests__ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2"
  }
}
