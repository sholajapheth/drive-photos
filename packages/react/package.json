{
  "name": "@drive-photos/react",
  "version": "0.1.0",
  "description": "React gallery and hooks for Google Drive photo folders",
  "license": "MIT",
  "author": {
    "name": "Shola Japheth",
    "url": "https://github.com/sholajapheth"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sholajapheth/drive-photos",
    "directory": "packages/react"
  },
  "homepage": "https://drive-photos.dev",
  "bugs": {
    "url": "https://github.com/sholajapheth/drive-photos/issues"
  },
  "keywords": [
    "google-drive",
    "photo-gallery",
    "react",
    "react-component",
    "image-gallery",
    "google-drive-api",
    "drive-photos",
    "react-gdrive"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "dist",
    "src/styles.css",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@drive-photos/core": "file:../core"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src __tests__ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  }
}
